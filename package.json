{
  "name": "nuxt-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint:js": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint": "yarn lint:js && yarn lint:prettier",
    "lint:fix": "prettier --write --list-different . && yarn lint:js --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev --preview-feature",
    "prisma:studio": "prisma studio",
    "prisma:db:push": "prisma db push",
    "prisma:db:pull": "prisma db pull",
    "postinstall": "nuxt prepare && prisma generate",
    "reset": "rimraf node_modules && rimraf .nuxt && rimraf .output && rimraf dist && yarn install",
    "l-reset": "rm -rf node_modules && rm -rf .nuxt && rm -rf .output && rm -rf dist && yarn install",
    "prune-branches": "git removed-branches --prune --force"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@vueuse/core": "13.4.0",
    "bcrypt": "^5.1.1",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.11",
    "kysely-postgres-js": "^3.0.0",
    "marked": "^15.0.7",
    "nodemailer": "^6.10.0",
    "prisma-kysely": "^3.1.0",
    "sanitize-html": "^2.14.0"
  },
  "devDependencies": {
    "@faker-js/faker": "10.3.0",
    "@nuxt/devtools": "3.2.3",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/ui": "4.5.1",
    "@nuxtjs/eslint-config-typescript": "12.1.0",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/bcrypt": "6.0.0",
    "@types/nodemailer": "7.0.11",
    "@types/sanitize-html": "2.16.1",
    "@typescript-eslint/parser": "8.57.0",
    "dayjs-nuxt": "2.1.11",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-perfectionist": "5.6.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-vue": "10.8.0",
    "nuxt": "4.4.2",
    "nuxt-auth-utils": "0.5.29",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.5.0",
    "rimraf": "6.1.3",
    "tailwindcss-debug-screens": "3.0.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vue": "latest",
    "zod": "4.3.6"
  },
  "volta": {
    "node": "24.14.0",
    "yarn": "1.22.22"
  }
}
