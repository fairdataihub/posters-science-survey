generator client {
    provider        = "prisma-client"
    previewFeatures = ["strictUndefinedChecks"]
    output          = "../shared/generated/"
    engineType      = "client"
}

generator kysely {
    provider = "prisma-kysely"

    output   = "../shared/generated/"
    fileName = "kysely.ts"
}

datasource db {
    provider = "postgresql"
}

model User {
    id          String   @id @default(cuid(2)) // token for the user (should be anonymous)
    posterOrder String[] // randomized poster IDs assigned on first survey visit

    created    DateTime     @default(now())
    updated    DateTime     @updatedAt
    evaluation evaluation[]
}

model Poster {
    id String @id @default(cuid(2))

    url String // hosted poster url

    created    DateTime     @default(now())
    updated    DateTime     @updatedAt
    evaluation evaluation[]
}

model evaluation {
    id String @id @default(cuid(2))

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    posterId String
    poster   Poster @relation(fields: [posterId], references: [id], onDelete: Cascade)

    isPoster   Boolean
    confidence Int // 1-5 confidence scale

    created DateTime @default(now())
    updated DateTime @updatedAt

    @@unique([userId, posterId])
}
